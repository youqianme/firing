{
  "name": "firing",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "config/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace=firing-web",
    "dev:mobile": "npm run start --workspace=firing-mobile",
    "build:web": "npm run build --workspace=firing-web",
    "build:mobile": "npm run export:web --workspace=firing-mobile",
    "start:web": "npm run start --workspace=firing-web",
    "lint": "eslint apps/ packages/",
    "db:init": "node scripts/init-db.mjs"
  },
  "devDependencies": {
    "@types/node": "20.11.19",
    "@types/react": "19.2.0",
    "@types/react-dom": "19.2.0",
    "autoprefixer": "10.4.17",
    "eslint": "^9.17.0",
    "eslint-config-next": "16.1.6",
    "postcss": "8.4.35",
    "tailwindcss": "3.4.1",
    "typescript": "5.3.3"
  }
}
