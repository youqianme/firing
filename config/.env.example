# 应用基础配置
NODE_ENV=development
NEXT_PUBLIC_APP_NAME="有钱么"
NEXT_PUBLIC_APP_VERSION="1.0.0"

# 服务器配置
PORT=3000
HOSTNAME=localhost

# 数据库配置（SQLite）
DB_PATH="./data/youqianme.db"
DB_VERBOSE=false

# 数据库配置（Neon / Vercel Postgres - 可选，优先于 Turso）
# Vercel 部署时会自动设置 POSTGRES_URL
NEON_DATABASE_URL=""
# POSTGRES_URL=""

# 数据库配置（LibSQL/Turso - 可选，用于 Vercel 等 Serverless 环境）
TURSO_DATABASE_URL=""
TURSO_AUTH_TOKEN=""

# 安全配置
NEXTAUTH_SECRET="your-secret-key-here"

# 功能开关
FEATURE_FIRE_CALCULATOR=true
FEATURE_MARKET_DATA=true
FEATURE_ASSET_INTEREST=true

# 外部 API 配置
# 市场数据 API（示例）
MARKET_DATA_API_KEY="your-api-key-here"
MARKET_DATA_API_URL="https://api.example.com/market-data"

# 货币汇率 API（示例）
EXCHANGE_RATE_API_KEY="your-api-key-here"
EXCHANGE_RATE_API_URL="https://api.example.com/exchange-rates"

# 日志配置
LOG_LEVEL=info
LOG_FILE="./logs/app.log"

# 性能配置
CACHE_DURATION=3600
MAX_UPLOAD_SIZE=1048576

# 开发环境配置
DEV_MODE=true
DEV_TOOLS=true

# 生产环境配置
# PROD_MODE=true
# HTTPS_ENABLED=true
# CDN_URL="https://cdn.example.com"